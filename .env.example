# Railway Environment Variables Template
# Copy this file and set the values in your Railway dashboard

# ===== REQUIRED SETTINGS =====
PORT=8080
ENVIRONMENT=production

# ===== CORS & SECURITY =====
# Add your frontend domain here (comma-separated)
# Example: https://your-frontend.railway.app,https://yourdomain.com
CORS_ORIGINS=https://*.railway.app,http://localhost:3000,http://localhost:5173

# Allowed hosts (comma-separated)
# Example: your-backend.railway.app,*.railway.app
ALLOWED_HOSTS=*.railway.app,localhost,127.0.0.1

# Secret key for JWT tokens (generate a strong random key)
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-secure-random-key

# ===== DATABASE SETTINGS =====
# For SQLite (default, works out of the box):
DB_PATH=/app/backend/database/fraud_logs.db

# For PostgreSQL (optional, comment out DB_PATH above if using):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=devops_shield
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_MIN_CONNECTIONS=5
# DB_MAX_CONNECTIONS=20
# DB_QUERY_CACHE=true
# DB_QUERY_CACHE_SIZE=1000

# ===== BLOCKCHAIN SETTINGS (Optional) =====
BLOCKCHAIN_ENABLED=false
# ETHEREUM_NETWORK=mainnet
# WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
# BLOCKCHAIN_PRIVATE_KEY=your-private-key

# ===== EXTERNAL INTEGRATIONS (Optional) =====
# GitLab
# GITLAB_TOKEN=your-gitlab-token
# GITLAB_URL=https://gitlab.com

# GitHub
# GITHUB_TOKEN=your-github-token

# Slack
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ===== PERFORMANCE & MONITORING =====
LOG_LEVEL=INFO
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Rate Limiting
# IP_WHITELIST_ENABLED=false

# ===== OPTIONAL FEATURES =====
# Enable/disable specific features
METRICS_ENABLED=true
TRACING_ENABLED=false

# ===== NOTES =====
# 1. Do NOT commit this file with actual secrets to version control
# 2. Set these variables in Railway dashboard under "Variables" tab
# 3. Railway automatically sets PORT - you can use PORT=8080 as default
# 4. CORS_ORIGINS should include your frontend domain after deployment
# 5. Generate a strong SECRET_KEY using: python -c "import secrets; print(secrets.token_urlsafe(32))"
